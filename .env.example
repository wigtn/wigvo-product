# =============================================================================
# WIGVO Monorepo — Environment Variables
# =============================================================================
# 이 파일을 루트 .env 로 복사 후 실제 값을 입력하세요.
#   cp .env.example .env
#
# relay-server 와 web 이 모두 이 파일을 참조합니다.
# =============================================================================

# --- OpenAI ---
OPENAI_API_KEY=sk-...
OPENAI_REALTIME_MODEL=gpt-4o-realtime-preview

# --- Langfuse (관측/추적, 선택) ---
# 비워두면 추적 비활성화 (통화에 영향 없음). cloud.langfuse.com 가입 → Settings 에서 키 발급.
# 자체 호스팅 시 LANGFUSE_HOST 를 본인 인스턴스 URL 로 변경.
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=https://cloud.langfuse.com
# 관측 환경 분리 — 부하/개발 트래픽이 실사용 데이터와 섞이면 품질 기준선과
# 평가셋(MEGA Loop 입력)이 오염된다. LOAD_TEST_MODE=true면 자동으로 load-test.
LANGFUSE_ENVIRONMENT=production

# --- Auth: wigsso (shared SSO Supabase project) ---
# wigvo Web 은 이 프로젝트로만 인증한다 (DB는 사용하지 않음).
# 키는 Supabase Dashboard > Settings > API 에서 확인.
NEXT_PUBLIC_SUPABASE_URL=https://juzzvlbadnfqdibtuhdi.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxxxxxxxx
SUPABASE_URL=https://juzzvlbadnfqdibtuhdi.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJxxxxxxxxx  # service_role JWT (admin API용)

# --- Relay tenant authentication (WI-4a) ---
# Generate an institution key once, give RELAY_API_KEY only to the Next server,
# and configure only its SHA-256 digest on relay. Keep enforce=false for the
# observe-only rollout, then switch to true after web/monitor verification.
# Generate: cd apps/relay-server && uv run python scripts/generate_tenant_api_key.py
RELAY_API_KEY=wigvo_replace_with_high_entropy_key
TENANT_API_KEY_HASHES={"00000000-0000-0000-0000-000000000001":["replace_with_sha256_hex"]}
TENANT_AUTH_ENFORCE=false
PICKUP_TOKEN_SECRET=replace_with_at_least_32_random_bytes
PICKUP_TOKEN_TTL_S=180
MAX_WAITING_CALLS=20
CLAIM_TTL_S=30
SESSION_STARTING_TIMEOUT_S=30
INBOUND_AGENT_CONNECT_TIMEOUT_S=15
INBOUND_WAIT_TIMEOUT_S=120
INBOUND_RECONNECT_GRACE_S=15
# handoff 직후 고지/hold 에코 잔향 억제 settling (초, 0=끔)
INBOUND_HANDOFF_SETTLING_S=1.5
DISPATCH_SWEEP_INTERVAL_S=5

# --- Local Postgres (DB) ---
# docker-compose 가 이 자격증명으로 wigvo-postgres 컨테이너를 띄우고,
# 같은 값으로 web/relay 컨테이너의 DATABASE_URL 을 합성한다.
POSTGRES_USER=wigvo
POSTGRES_PASSWORD=change_me_in_real_env
POSTGRES_DB=wigvo
# 호스트에서 직접 접속할 때 (drizzle-kit, 마이그레이션 스크립트 등) 사용.
# 컨테이너 내부에서는 docker-compose 가 자체적으로 DATABASE_URL 을 주입한다.
DATABASE_URL=postgresql://wigvo:change_me_in_real_env@127.0.0.1:10201/wigvo

# --- Twilio (Relay Server) ---
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx
# Twilio Console/REST에 등록되는 실제 외부 HTTPS origin (프록시 내부 URL 금지)
PUBLIC_CALLBACK_BASE_URL=https://relay.example.com

# --- Relay Server ---
RELAY_SERVER_URL=http://localhost:8000
RELAY_SERVER_PORT=8000
NEXT_PUBLIC_RELAY_WS_URL=ws://localhost:8000

# --- App ---
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# --- Call Limits (Relay Server) ---
MAX_CALL_DURATION_MS=600000
CALL_WARNING_MS=480000
CALL_MODE=realtime

# --- Logging (Relay Server) ---
LOG_LEVEL=INFO

# --- Feature Flags (Relay Server) ---
LOCAL_VAD_ENABLED=true
GUARDRAIL_ENABLED=true
# commit → TTS 도착까지 선제적으로 에코창을 여는 시간. 이 창이 열려 있는 동안
# 수신자 음성은 침묵으로 대체되므로 길수록 수신자가 오래 차단된다.
ECHO_PRE_ACTIVATE_TIMEOUT_S=2.5
GUARDRAIL_FALLBACK_MODEL=gpt-4o-mini

# --- CORS (Relay Server) ---
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000

# --- Operational thresholds (PoC refactor · FR-5.4/CP-2) ---
# Single source of truth for concurrency cap. Overrides config.py default (10).
# WI-1 load test (2 vCPU): stable ~20 / degraded 25 / saturated 30.
# NOTE: prod VM .env currently holds 50 (2.5x the safe line) — a separate
# restart-required action, not covered by editing this example file.
MAX_CONCURRENT_CALLS=20

# Process CPU is measured as process CPU seconds / wall time (one fully used
# core = 100%). Alert after N consecutive samples; all alerts share one
# Cloud Logging -> Monitoring channel documented in poc-refactor/WI5_poc-relay-runbook.md.
CPU_ALERT_THRESHOLD_PERCENT=85
CPU_ALERT_CONSECUTIVE_SAMPLES=3
OPENAI_ERROR_ALERT_THRESHOLD=5
OPENAI_ERROR_WINDOW_S=300
OPERATIONS_SAMPLE_INTERVAL_S=10
OPERATIONS_ALERT_COOLDOWN_S=300

# WI-1 load harness 전용. 운영 환경에서는 반드시 false.
LOAD_TEST_MODE=false

# WI-2 · §8-#6  Silero VAD ONNX 추론 오프로드용 고정 스레드풀 크기.
# 미설정 시 os.cpu_count()로 자동. ONNX가 GIL을 풀어 병렬도 상한이 코어 수이므로
# 통화 수가 아니라 코어 수 배수로 잡는다.
# VAD_POOL_WORKERS=
