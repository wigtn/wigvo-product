# =============================================================================
# WIGVO Monorepo — Environment Variables
# =============================================================================
# 이 파일을 루트 .env 로 복사 후 실제 값을 입력하세요.
#   cp .env.example .env
#
# relay-server 와 web 이 모두 이 파일을 참조합니다.
# =============================================================================

# --- OpenAI ---
OPENAI_API_KEY=sk-...
OPENAI_REALTIME_MODEL=gpt-4o-realtime-preview

# --- Langfuse (관측/추적, 선택) ---
# 비워두면 추적 비활성화 (통화에 영향 없음). cloud.langfuse.com 가입 → Settings 에서 키 발급.
# 자체 호스팅 시 LANGFUSE_HOST 를 본인 인스턴스 URL 로 변경.
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=https://cloud.langfuse.com

# --- Auth: wigsso (shared SSO Supabase project) ---
# wigvo Web 은 이 프로젝트로만 인증한다 (DB는 사용하지 않음).
# 키는 Supabase Dashboard > Settings > API 에서 확인.
NEXT_PUBLIC_SUPABASE_URL=https://juzzvlbadnfqdibtuhdi.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxxxxxxxx
SUPABASE_URL=https://juzzvlbadnfqdibtuhdi.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJxxxxxxxxx  # service_role JWT (admin API용)

# --- Local Postgres (DB) ---
# docker-compose 가 이 자격증명으로 wigvo-postgres 컨테이너를 띄우고,
# 같은 값으로 web/relay 컨테이너의 DATABASE_URL 을 합성한다.
POSTGRES_USER=wigvo
POSTGRES_PASSWORD=change_me_in_real_env
POSTGRES_DB=wigvo
# 호스트에서 직접 접속할 때 (drizzle-kit, 마이그레이션 스크립트 등) 사용.
# 컨테이너 내부에서는 docker-compose 가 자체적으로 DATABASE_URL 을 주입한다.
DATABASE_URL=postgresql://wigvo:change_me_in_real_env@127.0.0.1:10201/wigvo

# --- Twilio (Relay Server) ---
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# --- Relay Server ---
RELAY_SERVER_URL=http://localhost:8000
RELAY_SERVER_PORT=8000
NEXT_PUBLIC_RELAY_WS_URL=ws://localhost:8000

# --- App ---
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# --- Call Limits (Relay Server) ---
MAX_CALL_DURATION_MS=600000
CALL_WARNING_MS=480000
CALL_MODE=realtime

# --- Logging (Relay Server) ---
LOG_LEVEL=INFO

# --- Feature Flags (Relay Server) ---
LOCAL_VAD_ENABLED=true
GUARDRAIL_ENABLED=true
GUARDRAIL_FALLBACK_MODEL=gpt-4o-mini

# --- CORS (Relay Server) ---
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000
