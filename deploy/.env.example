# =============================================================================
# WIGVO cloud relay — copy to deploy/.env ON THE VM and fill real values.
# deploy/.env is gitignored. NEVER commit real secrets (this repo is PUBLIC).
# =============================================================================

# --- OpenAI ---
OPENAI_API_KEY=sk-REPLACE_ME
OPENAI_REALTIME_MODEL=gpt-realtime

# --- Twilio ---
TWILIO_ACCOUNT_SID=AC_REPLACE_ME
TWILIO_AUTH_TOKEN=REPLACE_ME
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX
PUBLIC_CALLBACK_BASE_URL=https://relay.wigvo.wigtn.com

# --- Supabase managed Postgres (US region) ---
# Use the POOLER (Supavisor) connection string, not the direct one.
DATABASE_URL=postgresql://USER:PASSWORD@POOLER_HOST:6543/postgres?pgbouncer=true

# --- WI-4a auth (relay stores only institution-key digests) ---
SUPABASE_URL=https://juzzvlbadnfqdibtuhdi.supabase.co
TENANT_API_KEY_HASHES={"00000000-0000-0000-0000-000000000001":["replace_with_sha256_hex"]}
TENANT_AUTH_ENFORCE=false
PICKUP_TOKEN_SECRET=replace_with_at_least_32_random_bytes
PICKUP_TOKEN_TTL_S=180
MAX_WAITING_CALLS=20
CLAIM_TTL_S=30
SESSION_STARTING_TIMEOUT_S=30
INBOUND_AGENT_CONNECT_TIMEOUT_S=15
INBOUND_WAIT_TIMEOUT_S=120
INBOUND_RECONNECT_GRACE_S=15
DISPATCH_SWEEP_INTERVAL_S=5

# --- This relay's public URL (used to build Twilio webhook + media-stream URLs) ---
RELAY_SERVER_URL=https://relay.wigvo.wigtn.com

# --- CORS: the Vercel web origin ---
ALLOWED_ORIGINS=https://wigvo.wigtn.com

# --- Call limits ---
MAX_CALL_DURATION_MS=600000
CALL_WARNING_MS=480000
MAX_CONCURRENT_CALLS=20

# --- Operations / Cloud Logging alert thresholds ---
CPU_ALERT_THRESHOLD_PERCENT=85
CPU_ALERT_CONSECUTIVE_SAMPLES=3
OPENAI_ERROR_ALERT_THRESHOLD=5
OPENAI_ERROR_WINDOW_S=300
OPERATIONS_SAMPLE_INTERVAL_S=10
OPERATIONS_ALERT_COOLDOWN_S=300

# --- Feature flags ---
LOCAL_VAD_ENABLED=true
GUARDRAIL_ENABLED=true

# --- Langfuse (optional; leave blank to disable) ---
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# --- Logging ---
LOG_LEVEL=INFO
